{
  "name": "@he/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/repository.test.ts src/breaker-repository.test.ts src/component-repository.test.ts src/server.test.ts src/floor-plans.test.ts src/floors.test.ts src/walls.test.ts src/rooms.test.ts src/switch-controls.test.ts",
    "start": "node --experimental-sqlite dist/index.js",
    "dev": "tsx watch --clear-screen=false --env-file=../../.env.dev src/index.ts"
  },
  "dependencies": {
    "@he/shared": "workspace:*",
    "hono": "^4.6.10",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2"
  }
}
