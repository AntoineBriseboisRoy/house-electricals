# =============================================================================
# House Electricals — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Local testing (build-from-source flavor):
#   docker compose up -d --build
#
# Production server (pulls pre-built image from GHCR):
#   See DEPLOYMENT.md + docs/CI-CD-SETUP.md.
#   Copy compose.prod.yaml → /srv/house-electricals/compose.yaml + this .env.
# =============================================================================

# ── Auth gate ────────────────────────────────────────────────────────────────
# Single-user login gate in front of every screen. There are NO
# AUTH_USERNAME / AUTH_PASSWORD env vars — the first time you open the
# app in a browser, a one-time sign-up screen lets you create the
# account. Credentials are scrypt-hashed and stored in Postgres
# (the `app_users` table).
#
# On first boot the backend auto-generates ${DATA_PATH}/.auth-secret
# (mode 600) used to sign session cookies. Back it up alongside the
# Postgres volume; deleting it invalidates every active session (the user
# row is untouched — they can sign back in).

# ── Host port ────────────────────────────────────────────────────────────────
# The container exposes a single host port. Your reverse proxy (Caddy /
# Cloudflare Tunnel / Nginx / Traefik) forwards to here.
HOST_PORT=8070

# ── Timezone ───────────────────────────────────────────────────────────────
# App-wide display timezone, as an IANA name (e.g. America/Toronto,
# Europe/Paris, Asia/Kolkata — see the "TZ identifier" column at
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones).
#
# The Node process uses it for date math, and the web UI reads it from
# /api/v1/config so every screen (audit log, service log, "last verified",
# printed diagram) shows dates in this zone regardless of the device you open
# the app on. Leave it commented/empty to fall back to each device's own local
# timezone (the default).
# TZ=America/Toronto

# ── Database (Postgres) ──────────────────────────────────────────────────────
# All relational data lives in Postgres, run as the `db` service in the
# compose files. These credentials seed the Postgres container AND build the
# DATABASE_URL the app connects with — keep them in sync. Use a strong
# POSTGRES_PASSWORD in production.
#
# The Postgres data is stored in the `he-pgdata` named Docker volume. Back it
# up regularly (e.g. `docker compose exec db pg_dump ...`) — it is the bulk of
# the app's state.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=house_electricals

# ── Data Storage ─────────────────────────────────────────────────────────────
# Host directory holding uploaded floor-plan images + the auto-generated
# .auth-secret. (Relational data lives in Postgres, not here.) Back up this
# directory alongside the Postgres volume.
#
# Local testing: defaults to ./data inside the repo (gitignored).
# Production: use an absolute path, e.g. /srv/house-electricals/data
#
# Linux note: the container runs as UID 65532 (distroless nonroot). On a
# fresh directory you must once run:
#   sudo chown -R 65532:65532 ${DATA_PATH}
DATA_PATH=./data

# ── Image reference (compose.prod.yaml only) ─────────────────────────────────
# REQUIRED for compose.prod.yaml — there is no default, so the operator can't
# accidentally pull a stale public maintainer image. Set this to YOUR fork's
# GHCR namespace (published by your own .github/workflows/release.yml run):
#
# IMAGE=ghcr.io/<your-github-username>/house-electricals:<channel>
#
# Pick a release CHANNEL by choosing the tag (see RELEASING.md for the full
# lifecycle):
#
#   :stable   — RECOMMENDED. Moves only when a clean version tag (vX.Y.Z) is
#               pushed. Soak-tested; what most self-hosters should run.
#   :latest   — alias of :stable (the Docker convention: newest stable
#               release). Same image as :stable.
#   :beta     — moves when a pre-release tag (vX.Y.Z-rc.N) is pushed. Early
#               access to the next release while it's being stabilized.
#   :nightly  — moves on every push to main. Newest code, may be rough.
#
# For a frozen rollback target, pin an immutable tag instead of a channel:
#   :X.Y.Z      a specific release (e.g. :1.4.0)        — from a clean tag
#   :sha-<full> a specific commit                       — from any build
#
# Examples:
# IMAGE=ghcr.io/<your-github-username>/house-electricals:stable
# IMAGE=ghcr.io/<your-github-username>/house-electricals:1.4.0
# IMAGE=ghcr.io/<your-github-username>/house-electricals:nightly
