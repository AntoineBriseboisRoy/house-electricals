# =============================================================================
# House Electricals — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Local testing (build-from-source flavor):
#   docker compose up -d --build
#
# Production server (pulls pre-built image from GHCR):
#   See DEPLOYMENT.md + docs/CI-CD-SETUP.md.
#   Copy compose.prod.yaml → /srv/house-electricals/compose.yaml + this .env.
# =============================================================================

# ── Host port ────────────────────────────────────────────────────────────────
# The container exposes a single host port. Your reverse proxy (Caddy /
# Cloudflare Tunnel / Nginx / Traefik) forwards to here.
HOST_PORT=8070

# ── Data Storage ─────────────────────────────────────────────────────────────
# Host directory holding SQLite (panels.db + WAL) and uploaded floor-plan
# images. Back up this directory regularly — it is the only state the app
# has.
#
# Local testing: defaults to ./data inside the repo (gitignored).
# Production: use an absolute path, e.g. /srv/house-electricals/data
#
# Linux note: the container runs as UID 65532 (distroless nonroot). On a
# fresh directory you must once run:
#   sudo chown -R 65532:65532 ${DATA_PATH}
DATA_PATH=./data

# ── Image reference (compose.prod.yaml only) ─────────────────────────────────
# Defaults to the maintainer's published image. The :latest tag moves with
# every push to main; pin to a specific commit SHA (e.g. :a1b2c3...) for a
# stable rollback target.
#
# If you forked this repo and want your server to pull YOUR fork's images
# (published by your own .github/workflows/release.yml run), override here
# with your GHCR namespace:
#
# IMAGE=ghcr.io/antoinebriseboisroy/house-electricals:latest
# IMAGE=ghcr.io/<your-github-username>/house-electricals:latest
