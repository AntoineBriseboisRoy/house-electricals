# Local-dev environment for `pnpm dev`.
#
# The backend's defaults assume docker absolute paths (/data/panels.db,
# /data/floor-plans). For local dev we point at ./data inside the repo.
# Node 22+ reads this via --env-file in the backend's `dev` script.
#
# Don't commit any actual secrets here — this file ships as the dev default
# and is meant to be safe to read into a running backend process.

DB_PATH=./data/panels.db
FLOOR_PLAN_DIR=./data/floor-plans
PORT=3000
HOST=127.0.0.1

# Auth: first time you visit http://localhost:5173 the app shows a
# sign-up screen — create whatever username + password you want. The
# credentials get hashed (scrypt) and stored in ./data/panels.db. The
# session-signing AUTH_SECRET auto-generates into ./data/.auth-secret
# on first boot. To "reset" the dev account, rm -rf ./data and you'll
# get the sign-up screen again.
