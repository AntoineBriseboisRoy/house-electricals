# Local-dev environment for `pnpm dev`.
#
# Relational data lives in Postgres. `docker-compose.dev.yml` runs a local
# Postgres on host port 5433 (so it never clashes with a system Postgres on
# the default 5432). Start it with:
#
#   docker compose -f docker-compose.dev.yml up -d
#
# Uploaded floor-plan images + the auto-generated .auth-secret still live on
# disk under ./data. Node 22+ reads this file via --env-file in the backend's
# `dev` script.
#
# Don't commit any actual secrets here — this file ships as the dev default
# and is meant to be safe to read into a running backend process.

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/house_electricals
FLOOR_PLAN_DIR=./data/floor-plans
# Where the auto-generated .auth-secret is written. In the container this
# defaults to /data; for host-run `pnpm dev` we point it at the repo's ./data
# (otherwise it would try to write to the absolute /data at the FS root).
DATA_DIR=./data
PORT=3000
HOST=127.0.0.1

# Auth: first time you visit http://localhost:5173 the app shows a
# sign-up screen — create whatever username + password you want. The
# credentials get hashed (scrypt) and stored in the `app_users` table in
# Postgres. The session-signing AUTH_SECRET auto-generates into
# ./data/.auth-secret on first boot. To "reset" the dev account, wipe the
# Postgres volume (docker compose -f docker-compose.dev.yml down -v) and
# rm -rf ./data, then you'll get the sign-up screen again.
